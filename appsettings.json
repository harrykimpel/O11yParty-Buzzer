{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "NewRelic": {
    "IngestApiKey": "",
    "AccountId": "",
    "Region": "US",
    "EventType": "O11yPartyBuzz",
    "LeadCaptureEventType": "O11yPartyLeadCapture",
    "EventPublishTimeoutSeconds": 15,
    "CircuitBreakerFailureThreshold": 3,
    "CircuitBreakerBreakDurationSeconds": 60
  },
  "Resilience": {
    "RequestTimeoutSeconds": 30,
    "BlazorDisconnectedCircuitMaxRetained": 100,
    "BlazorDisconnectedCircuitRetentionMinutes": 3,
    "BlazorJsInteropCallTimeoutSeconds": 30,
    "BlazorHubClientTimeoutSeconds": 30,
    "BlazorHubHandshakeTimeoutSeconds": 15,
    "BlazorHubKeepAliveIntervalSeconds": 15
  },
  "AllowedHosts": "*"
}
