@page "/"

<PageTitle>O11yParty-Buzzer</PageTitle>

@*
    Static server-rendered page. Interactivity (lead gate + buzz) is handled by
    wwwroot/buzzer.js via fetch() to /api/lead-capture and /api/buzz — there is NO
    Blazor Server circuit. The DOM ids/classes below are the JS + load-test contract;
    keep them stable (notably #teamName, button.buzzer-button, p.status.ok/.error,
    .lead-gate, and the success text "Buzz received for {team}.").
*@

<section class="buzzer-stage">
	<main class="buzzer-shell is-locked" id="buzzerShell" aria-hidden="true">
		<p>Enter your team name and hit the buzzer to answer the question.</p>

		<label for="teamName">Team Name</label>
		<input id="teamName" class="team-input" maxlength="80" placeholder="Team Rocket" />

		<button class="buzzer-button" id="buzzButton" type="button">BUZZ</button>

		<p class="status" id="buzzStatus" role="status" aria-live="polite" hidden></p>
	</main>

	<section class="lead-gate" id="leadGate" role="dialog" aria-modal="true" aria-labelledby="leadGateTitle">
		<div class="lead-gate-card">
			<h2 id="leadGateTitle">Before You Buzz</h2>
			<p>Please complete the required details to continue.</p>

			<div class="lead-grid">
				<div class="lead-field">
					<label for="firstName">First Name</label>
					<input id="firstName" class="lead-input" required maxlength="100" />
				</div>
				<div class="lead-field">
					<label for="lastName">Last Name</label>
					<input id="lastName" class="lead-input" required maxlength="100" />
				</div>
				<div class="lead-field lead-field-wide">
					<label for="businessEmail">Business Email Address</label>
					<input id="businessEmail" class="lead-input" required type="email" maxlength="180" />
				</div>
				<div class="lead-field">
					<label for="companyName">Company Name</label>
					<input id="companyName" class="lead-input" required maxlength="150" />
				</div>
				<div class="lead-field">
					<label for="jobTitle">Job Title</label>
					<input id="jobTitle" class="lead-input" required maxlength="120" />
				</div>
				<div class="lead-field lead-field-wide">
					<label for="country">Country</label>
					<input id="country" class="lead-input" required maxlength="120" />
				</div>
			</div>

			<p class="lead-error" id="leadError" hidden></p>

			<button class="lead-submit" id="leadSubmit" type="button">Continue To Buzzer</button>
		</div>
	</section>
</section>
