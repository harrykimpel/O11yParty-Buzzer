@inherits LayoutComponentBase

<div class="page">
    <main>
        <div class="theme-toolbar">
            <button type="button" class="theme-toggle" onclick="window.o11yTheme.toggle()" title="Switch theme"
                    aria-label="Switch theme">Dark</button>
        </div>
        <div class="hero-image-wrap">
            <img src="images/O11y-Party.png" alt="Observability Party banner" class="hero-image" />
        </div>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>