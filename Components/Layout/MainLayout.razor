@inherits LayoutComponentBase

<div class="page">
    <main>
        <div class="theme-toolbar">
            <button type="button" class="theme-toggle" onclick="window.o11yTheme.toggle()" title="Switch to Light theme"
                    aria-label="Switch to Light theme">Light</button>
        </div>
        <header class="wth-header-cosmic">
            <div class="cosmic-bg">
                <div class="cosmic-stars"></div>
                <div class="cosmic-nebula"></div>
                <div class="cosmic-flowers">
                    <div class="flower f1"></div>
                    <div class="flower f2"></div>
                    <div class="flower f3"></div>
                    <div class="flower f4"></div>
                    <div class="flower f5"></div>
                    <div class="flower f6"></div>
                    <div class="flower f7"></div>
                    <div class="flower f8"></div>
                    <div class="flower f9"></div>
                    <div class="flower f10"></div>
                    <div class="flower f11"></div>
                    <div class="flower f12"></div>
                </div>
                <div class="cosmic-glow"></div>
            </div>
            <div class="cosmic-content">
                <h1 class="cosmic-title">O11y-Party Buzzer</h1>
            </div>
        </header>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>